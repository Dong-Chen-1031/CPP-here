---
import * as ls from "@/store/atom";

const lsVersion = {
  code: "1",
  cppVersion: "1",
  input: "1",
  output: "1",
  runMode: "1",
  testCases: "1",
};
---

<!doctype html>
<html class="neutral dark bg-background text-foreground">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.svg" />
    <meta name="generator" content={Astro.generator} />

    <title>C++ Here</title>

    <script is:inline define:vars={{ lsVersion }}>
      const lsKeys = "lsVersion";
      const cls = JSON.parse(localStorage.getItem(lsKeys));
      for (const key in lsVersion) {
        if (!cls || cls[key] !== lsVersion[key]) {
          localStorage.removeItem(key);
          console.log(
            `Cleared localStorage key: ${key} due to version mismatch.`,
          );
        }
      }
      localStorage.setItem(lsKeys, JSON.stringify(lsVersion));
    </script>

