---
import {
    BinaryIcon,
    CircleAlertIcon,
    FlaskConicalIcon,
    SparklesIcon,
    LanguagesIcon,
    WandSparklesIcon,
} from "@lucide/astro";

import { SiGithub } from "@icons-pack/react-simple-icons";
import config from "@/config/constants";

const features = [
    {
        icon: BinaryIcon,
        title: "C++ to WebAssembly",
        titleZh: "C++ 轉 WebAssembly 編譯服務",
        desc: "Compiles C++ code into WebAssembly and executes them directly in the browser — fast, no resource limitations.",
        descZh: "將 C++ 程式碼編譯為 WebAssembly 並直接於瀏覽器執行，快速且無資源限制。",
    },
    {
        icon: CircleAlertIcon,
        title: "Error Highlighting",
        titleZh: "錯誤標示與診斷e化功能",
        desc: "Compiler errors are parsed and pinned to the exact line they occur — clear, actionable diagnostics without the noise.",
        descZh: "編譯器錯誤將精確標示於對應行號，提供清晰可操作之診斷資訊。",
    },
    {
        icon: FlaskConicalIcon,
        title: "Built-in Test Cases",
        titleZh: "內建測試案例管理系統",
        desc: "Define, run, and compare multiple test cases side-by-side. Designed for the way competitive programmers actually work.",
        descZh: "可定義、執行並並排比較多組測試案例，專為競技程式設計使用者設計。",
    },
    {
        icon: SparklesIcon,
        title: "Code Formatting",
        titleZh: "程式碼格式化e化服務",
        desc: "Clang-format integrated. One shortcut to keep your style consistent across every snippet you write.",
        descZh: "整合 Clang-format，一鍵保持程式碼格式一致，提升作業效率。",
    },
    {
        icon: LanguagesIcon,
        title: "i18n Ready",
        titleZh: "多國語系e化支援",
        desc: "First-class support for English and Traditional Chinese, with more languages on the way.",
        descZh: "完整支援英文及繁體中文，更多語系持續開發中，歡迎協助翻譯。",
    },
    {
        icon: WandSparklesIcon,
        title: "Smart Autocomplete",
        titleZh: "智慧型程式碼自動補全",
        desc: "Context-aware suggestions for STL containers, algorithms, and your own symbols — write C++ faster without leaving the flow.",
        descZh: "提供 STL 容器、演算法及自訂符號之情境感知建議，大幅提升撰碼效率。",
    },
];
---

<section id="features" style="padding:0 14px 14px;font-family:'Microsoft JhengHei',Arial,sans-serif;">
    <div class="roc-box" style="overflow:hidden;">
        <div class="roc-section-header">◆ 系統e化功能說明一覽表【共 {features.length} 項核心功能】</div>

        <div style="padding:10px 12px 12px;">
            <p style="font-size:12px;color:#555;margin-bottom:8px;border-left:3px solid #000095;padding-left:7px;line-height:1.6;">
                以下為本系統所提供之各項e化核心功能說明，請詳細閱讀以充分利用本系統之各項服務。
            </p>

            <table class="roc-table" style="width:100%;margin-bottom:10px;">
                <thead>
                    <tr>
                        <th style="width:44px;text-align:center;">序號</th>
                        <th style="width:200px;">功能名稱（中文）</th>
                        <th>功能說明</th>
                    </tr>
                </thead>
                <tbody>
                    {features.map(({ icon: Icon, titleZh, descZh }, i) => (
                        <tr class="roc-stat-row">
                            <td style="text-align:center;font-size:12px;color:#555;">{String(i + 1).padStart(2, "0")}</td>
                            <td>
                                <div style="display:flex;align-items:center;gap:6px;">
                                    <span style="color:#000095;"><Icon class="size-4" /></span>
                                    <span style="font-weight:bold;font-size:13px;">{titleZh}</span>
                                </div>
                            </td>
                            <td style="font-size:12px;color:#333;line-height:1.65;" set:html={descZh} />
                        </tr>
                    ))}
                    <!-- 開放原始碼說明列 -->
                    <tr style="background:hsl(52,94%,88%);">
                        <td style="text-align:center;font-size:12px;color:#555;">★</td>
                        <td>
                            <div style="display:flex;align-items:center;gap:6px;">
                                <span style="color:#333;"><SiGithub className="size-4" /></span>
                                <span style="font-weight:bold;font-size:13px;">開放原始碼 · MIT 授權</span>
                            </div>
                        </td>
                        <td style="font-size:12px;color:#333;line-height:1.65;">
                            本系統採 MIT 授權條款釋出，歡迎查閱、派生及部署。原始碼均公開於 GitHub，接受社群回報問題。
                            <a href={config.githubLink} target="_blank" rel="noopener noreferrer" style="color:#0000cc;margin-left:4px;">前往 GitHub 原始碼下載區 →</a>
                        </td>
                    </tr>
                </tbody>
            </table>

            <div style="text-align:right;font-size:11px;color:#888;border-top:1px solid #ddd;padding-top:6px;">
                ◎ 本功能說明表資料更新時間：{new Date().getFullYear()}年 ｜ 如有疑問請至 GitHub 提出
            </div>
        </div>
    </div>
</section>

