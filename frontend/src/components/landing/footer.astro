---
import config from "@/config/constants";

const links = [
    { label: "Editor", href: config.editorLink },
    { label: "GitHub", href: config.githubLink, external: true },
    {
        label: "Status",
        href: `https://status.doong.me/status/cpp-here`,
        external: true,
    },
];
---

<footer style="background:#222;color:#ccc;font-family:'Microsoft JhengHei',Arial,Tahoma,sans-serif;border-top:4px solid #000095;">
    <div style="display:grid;grid-template-columns:1fr 1fr 1fr;gap:0;border-bottom:1px solid #444;">
        <!-- 系統簡介 -->
        <div style="padding:16px 18px;border-right:1px solid #3a3a3a;">
            <div style="font-size:13px;font-weight:bold;color:#fff;border-bottom:1px solid #444;padding-bottom:6px;margin-bottom:10px;letter-spacing:0.3px;">
                ◆ 系統簡介
            </div>
            <p style="font-size:12px;line-height:1.75;color:#bbb;">
                「C++ Here」係提供全民免費使用之瀏覽器內建 C++ 程式編輯與編譯e化服務平台，採 MIT 授權條款釋出，無需安裝，隨開即用。
            </p>
            <div style="margin-top:10px;font-size:11px;color:#888;">
                授權：MIT License ｜ 完全免費
            </div>
        </div>

        <!-- e化快速連結 -->
        <div style="padding:16px 18px;border-right:1px solid #3a3a3a;">
            <div style="font-size:13px;font-weight:bold;color:#fff;border-bottom:1px solid #444;padding-bottom:6px;margin-bottom:10px;letter-spacing:0.3px;">
                ◆ e化服務快速連結
            </div>
            <ul style="list-style:none;padding:0;margin:0;font-size:12px;line-height:2.2;">
                {links.map(({ label, href, external }) => (
                    <li>
                        <a
                            href={href}
                            style="color:#88aaff;"
                            class="roc-footer-link"
                            {...(external ? { target: "_blank", rel: "noopener noreferrer" } : {})}
                        >▸ {label}</a>
                    </li>
                ))}
                <li>
                    <a href="https://crowdin.com/project/cpp-here" target="_blank" rel="noopener noreferrer" style="color:#88aaff;" class="roc-footer-link">▸ 協助翻譯（Crowdin）</a>
                </li>
                <li>
                    <a href={`${config.githubLink}/blob/main/LICENSE.txt`} target="_blank" rel="noopener noreferrer" style="color:#88aaff;" class="roc-footer-link">▸ MIT 授權條款</a>
                </li>
            </ul>
        </div>

        <!-- 聯絡資訊 -->
        <div style="padding:16px 18px;">
            <div style="font-size:13px;font-weight:bold;color:#fff;border-bottom:1px solid #444;padding-bottom:6px;margin-bottom:10px;letter-spacing:0.3px;">
                ◆ 聯絡資訊與服務窗口
            </div>
            <table style="width:100%;border-collapse:collapse;font-size:12px;">
                <tr>
                    <td style="padding:3px 0;color:#999;white-space:nowrap;padding-right:8px;">開發者</td>
                    <td style="padding:3px 0;color:#ddd;">Dong-Chen-1031</td>
                </tr>
                <tr>
                    <td style="padding:3px 0;color:#999;white-space:nowrap;padding-right:8px;">問題回報</td>
                    <td style="padding:3px 0;">
                        <a href={`${config.githubLink}/issues`} target="_blank" rel="noopener noreferrer" style="color:#88aaff;" class="roc-footer-link">GitHub Issues</a>
                    </td>
                </tr>
                <tr>
                    <td style="padding:3px 0;color:#999;white-space:nowrap;padding-right:8px;">系統狀態</td>
                    <td style="padding:3px 0;">
                        <a href="https://status.doong.me/status/cpp-here" target="_blank" rel="noopener noreferrer" style="color:#88aaff;" class="roc-footer-link">status.doong.me</a>
                    </td>
                </tr>
                <tr>
                    <td style="padding:4px 0;color:#999;white-space:nowrap;padding-right:8px;">版本管理</td>
                    <td style="padding:4px 0;">
                        <a href={`${config.githubLink}/releases`} target="_blank" rel="noopener noreferrer" style="color:#88aaff;" class="roc-footer-link">GitHub Releases</a>
                    </td>
                </tr>
            </table>
        </div>
    </div>

    <!-- 版權列 -->
    <div style="padding:6px 18px;background:#1a1a1a;display:flex;justify-content:space-between;align-items:center;font-size:11px;color:#666;">
        <span>© {new Date().getFullYear()} Dong-Chen-1031 ｜ MIT Licensed ｜ 本系統由 C++ Here 開源專案維護</span>
        <span style="color:#444;">版本資訊請至 GitHub 查詢</span>
    </div>
</footer>

