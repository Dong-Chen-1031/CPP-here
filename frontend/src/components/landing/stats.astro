---
import { ZapIcon, FileTextIcon, DatabaseIcon, ClockIcon } from "@lucide/astro";
import Hr from "@/components/landing/hr.astro";
import config from "@/config/constants";

interface StatusResponse {
    total_count: number;
    total_lines: number;
    total_wasm_size_bytes: number;
    total_duration_seconds: number;
}

function formatCount(n: number | undefined): string {
    if (n === undefined) return "-";
    if (n >= 1_000_000)
        return (n / 1_000_000).toFixed(1).replace(/\.0$/, "") + "M+";
    if (n >= 1_000) return (n / 1_000).toFixed(1).replace(/\.0$/, "") + "K+";
    return String(n);
}

function formatLines(n: number | undefined): string {
    if (n === undefined) return "-";
    if (n >= 1_000_000)
        return (n / 1_000_000).toFixed(1).replace(/\.0$/, "") + "M+";
    if (n >= 1_000) return (n / 1_000).toFixed(1).replace(/\.0$/, "") + "K+";
    return String(n);
}

function formatBytes(bytes: number | undefined): string {
    if (bytes === undefined) return "-";
    if (bytes >= 1_073_741_824)
        return (bytes / 1_073_741_824).toFixed(1).replace(/\.0$/, "") + " GB+";
    if (bytes >= 1_048_576)
        return (bytes / 1_048_576).toFixed(1).replace(/\.0$/, "") + " MB+";
    if (bytes >= 1_024)
        return (bytes / 1_024).toFixed(1).replace(/\.0$/, "") + " KB+";
    return bytes + " B";
}

function formatDuration(seconds: number | undefined): string {
    if (seconds === undefined) return "-";
    if (seconds >= 86_400)
        return (seconds / 86_400).toFixed(1).replace(/\.0$/, "") + " days+";
    if (seconds >= 3_600)
        return (seconds / 3_600).toFixed(1).replace(/\.0$/, "") + " hrs+";
    if (seconds >= 60)
        return (seconds / 60).toFixed(1).replace(/\.0$/, "") + " min+";
    return seconds.toFixed(0) + " s+";
}

let apiData: StatusResponse | null = null;
try {
    const res = await fetch(`${config.buildTimeAPIEndpoint}/status`);
    if (res.ok) apiData = await res.json();

    if (!apiData) {
        console.error("API data is null");
        throw new Error("Failed to load stats data");
    }
} catch (error) {
    if (config.run_mode === "development" || config.skipApiFetch) {
        console.warn(
            `Failed to fetch stats from API: ${error}\nSkipping API fetch in development mode or due to configuration.`,
        );
        apiData = null;
    } else throw new Error(`Failed to fetch stats from API: ${error}`);
}

const stats = [
    {
        icon: ZapIcon,
        value: formatCount(apiData?.total_count),
        label: "Compilations",
        desc: "C++ programs compiled and executed directly in the browser.",
    },
    {
        icon: FileTextIcon,
        value: formatLines(apiData?.total_lines),
        label: "Lines Compiled",
        desc: "Lines of C++ code processed through the WebAssembly pipeline.",
    },
    {
        icon: DatabaseIcon,
        value: formatBytes(apiData?.total_wasm_size_bytes),
        label: "Wasm Compiled",
        desc: "Total size of source code submitted and compiled by users.",
    },
    {
        icon: ClockIcon,
        value: formatDuration(apiData?.total_duration_seconds),
        label: "Total Time Compiled",
        desc: "Cumulative CPU time spent compiling across all users.",
    },
];
---

<section id="stats" style="padding:0 14px 14px;font-family:'Microsoft JhengHei',Arial,sans-serif;">
    <div class="roc-box" style="overflow:hidden;">
        <div class="roc-section-header">◆ 系統e化作業統計資料查詢專區【即時數據資訊】</div>

        <div style="padding:10px 12px 12px;">
            <p style="font-size:12px;color:#555;margin-bottom:10px;border-left:3px solid #000095;padding-left:7px;line-height:1.6;">
                以下統計資料係由本系統後端API即時彙整提供，數據反映系統自上線以來之累計使用情形，供各界查詢參考。
            </p>

            <table class="roc-table" style="width:100%;margin-bottom:10px;">
                <thead>
                    <tr>
                        <th style="width:44px;text-align:center;">項次</th>
                        <th style="width:220px;">統計項目名稱</th>
                        <th style="width:130px;text-align:right;">累計數量</th>
                        <th>說明</th>
                    </tr>
                </thead>
                <tbody>
                    {stats.map(({ icon: Icon, value, label, desc }, i) => (
                        <tr class="roc-stat-row">
                            <td style="text-align:center;font-size:12px;color:#555;">{String(i + 1).padStart(2, "0")}</td>
                            <td>
                                <div style="display:flex;align-items:center;gap:6px;">
                                    <span style="color:#000095;"><Icon class="size-4" /></span>
                                    <span style="font-weight:bold;font-size:13px;">{label}</span>
                                </div>
                            </td>
                            <td style="text-align:right;font-size:16px;font-weight:bold;color:#000095;letter-spacing:0.5px;font-family:Arial,sans-serif;">{value}</td>
                            <td style="font-size:12px;color:#444;line-height:1.6;">{desc}</td>
                        </tr>
                    ))}
                </tbody>
            </table>

            <div style="display:flex;justify-content:space-between;align-items:center;border-top:1px solid #ddd;padding-top:6px;">
                <span style="font-size:11px;color:#888;">◎ 資料來源：本系統後端API即時統計 ｜ 數據建置時間：{new Date().getFullYear()}年</span>
                <span style="font-size:11px;color:{apiData ? '#006600' : '#cc6600'};font-weight:bold;">
                    {apiData ? "● 資料載入正常" : "● 資料暫時無法取得（顯示預設值）"}
                </span>
            </div>
        </div>
    </div>
</section>

