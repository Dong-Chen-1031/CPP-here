---
import Layout from "@/layouts/Layout.astro";
import "@/styles/landing.css";
import Header from "@/components/landing/header.astro";
import Hero from "@/components/landing/hero.astro";
import Features from "@/components/landing/features.astro";
import Extension from "@/components/landing/extension.astro";
import Stats from "@/components/landing/stats.astro";
import CTA from "@/components/landing/CTA.astro";
import Footer from "@/components/landing/footer.astro";
---

<!-- 
1. header v
2. hero v
3. features v
    (1) C++ to WebAssembly
    (2) error hinting
    (3) test case
    (4) code formatting
    (5) i18n V
    (6) built for competitive programming
    (7) open-source and free to use
    (8) TODO: RWD support
4. extensions V
5. data V
6. CAT V
7. footer V
-->
<Layout
    title="C++ Here - Next-generation online C++ editor."
    description="An open-source, lightweight yet powerful online C++ editor built for competitive programming. Compile C++ to WebAssembly, run test cases, and format code — all in your browser.">
    <meta
        slot="head"
        name="viewport"
        content="width=device-width, initial-scale=1.0"
    />
    <script slot="head" type="application/ld+json" is:inline>
        {
            "@context": "https://schema.org",
            "@type": "SoftwareApplication",
            "name": "C++ Here",
            "url": "https://cpp.doong.me",
            "description": "An open-source, lightweight yet powerful online C++ editor built for competitive programming.",
            "applicationCategory": "DeveloperApplication",
            "operatingSystem": "Web Browser",
            "offers": {
                "@type": "Offer",
                "price": "0",
                "priceCurrency": "USD"
            },
            "featureList": [
                "C++ to WebAssembly compilation",
                "Error highlighting",
                "Built-in test cases",
                "Code formatting with Clang-format",
                "i18n support",
                "Smart autocomplete",
                "Responsive design — works on any screen and device",
                "Secured by Cloudflare Turnstile and isolated Docker containers",
                "One-click code sharing"
            ],
            "codeRepository": "https://github.com/Dong-Chen-1031/CPP-here",
            "license": "https://github.com/Dong-Chen-1031/CPP-here/blob/main/LICENSE.txt"
        }
    </script>
    <style>
        html,
        body {
            overflow-x: hidden;
            height: 100%;
        }
    </style>
    <div class="mono tracking-tight">
        <Header />
        <Hero />
        <Features />
        <Extension />
        <Stats />
        <CTA />
        <Footer />
    </div>
</Layout>
