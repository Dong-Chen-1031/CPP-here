# PUBLIC_CAPTCHA_SITE_KEY="1x00000000000000000000BB"
# Cloudflare Turnstile site key for CAPTCHA verification.
# Get a real site key from Cloudflare Turnstile dashboard for production use.
# Default: "1x00000000000000000000BB" (Always valid for development).


# PUBLIC_API_URL="http://127.0.0.1:8000"
# Backend API URL to fetch data. In development, it points to the local backend server. 
# In production, it should point to the deployed backend API.
# Default: "http://127.0.0.1:8000".

# SKIP_API_FETCH="true"
# Set to "true" to skip API fetches for landing page stats data at build time.
# If your backend is not ready, you can set this to "true" during development.
# Default: "true".

# PUBLIC_BUILD_TIME_API_URL="http://127.0.0.1:8000"
# Backend API URL to fetch data at build time. 
# If you are using docker, you need to set this to Docker internal host to allow the build process to fetch data from the backend container.
# Or you can just set SKIP_API_FETCH to "true" to skip API fetches during build time.
# Default: not set (falls back to PUBLIC_API_URL).

# PUBLIC_SHARE="true"
# Set to "true" to enable sharing features in the frontend.
# Default: "false".

# PUBLIC_S3_BUCKET_URL=""
# If you want to use shared features, you need to set up an S3-compatible storage and provide the bucket URL here for the frontend to access shared code.