{
  "name": "frontend",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "copy-i18n": "cp -r ./i18n ./frontend/public/",
    "frontend": "bun copy-i18n && cd frontend && astro dev --host",
    "backend": "cd backend && python main.py",
    "dev": "PUBLIC_RUN_MODE=dev concurrently \"bun run frontend\" \"bun run backend\"",
    "build": "bun copy-i18n && cd frontend && astro build",
    "preview": "bun copy-i18n && cd frontend && astro preview",
    "astro": "bun copy-i18n && cd frontend && astro",
    "ext:chrome": "cd extensions && bun dev:chrome",
    "ext:firefox": "cd extensions && bun dev:firefox"
  },
  "dependencies": {
    "@astrojs/react": "^4.4.2",
    "@codemirror/autocomplete": "^6.20.1",
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/theme-one-dark": "^6.1.3",
    "@lucide/astro": "^0.576.0",
    "@marsidev/react-turnstile": "^1.4.2",
    "@tailwindcss/vite": "^4.2.1",
    "@types/react-dom": "^19.2.3",
    "@uiw/codemirror-theme-vscode": "^4.25.7",
    "@uiw/react-codemirror": "^4.25.7",
    "astro": "^5.17.1",
    "axios": "^1.13.6",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "concurrently": "^9.2.1",
    "i18next": "^26.0.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "i18next-http-backend": "^3.0.2",
    "jotai": "^2.18.0",
    "lucide-react": "^0.576.0",
    "motion": "^12.38.0",
    "radix-ui": "^1.4.3",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "react-i18next": "^17.0.1",
    "react-resizable-panels": "^4.7.1",
    "shadcn": "^3.8.5",
    "tailwind-merge": "^3.5.0",
    "tailwindcss": "^4.2.1",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2"
  },
  "devDependencies": {
    "@types/react": "^19.2.14"
  }
}
