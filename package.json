{
    "name": "frontend",
    "type": "module",
    "version": "0.0.1",
    "scripts": {
        "copy-i18n": "cp -r ./i18n ./frontend/public/",
        "copy-docker": "mkdir -p ./frontend/public/script && cp -r ./docker/* ./frontend/public/script",
        "frontend": "bun copy-i18n && cd frontend && bun run logo && astro dev --host",
        "backend": "cd backend && python main.py",
        "dev": "NO_LOGO=true concurrently \"bun run frontend\" \"bun run backend\"",
        "build": "bun copy-i18n && bun copy-docker && bun run logo && cd frontend && astro build",
        "preview": "bun copy-i18n && cd frontend && bun run logo && astro preview",
        "astro": "bun copy-i18n && bun run logo && cd frontend && astro",
        "ext:chrome": "cd extensions && bun dev:chrome",
        "ext:firefox": "cd extensions && bun dev:firefox",
        "logo": "bun run frontend/src/lib/printLogo.ts"
    },
    "dependencies": {
        "@astrojs/react": "^4.4.2",
        "@astrojs/sitemap": "^3.7.3",
        "@base-ui/react": "^1.4.1",
        "@codemirror/autocomplete": "^6.20.2",
        "@codemirror/lang-cpp": "^6.0.3",
        "@codemirror/theme-one-dark": "^6.1.3",
        "@icons-pack/react-simple-icons": "^13.13.0",
        "@lucide/astro": "^0.576.0",
        "@marsidev/react-turnstile": "^1.5.2",
        "@tailwindcss/vite": "^4.3.0",
        "@types/react-dom": "^19.2.3",
        "@uiw/codemirror-theme-vscode": "^4.25.9",
        "@uiw/react-codemirror": "^4.25.9",
        "@wasm-fmt/clang-format": "^22.1.5",
        "astro": "^5.18.1",
        "axios": "1.16.1",
        "class-variance-authority": "^0.7.1",
        "clsx": "^2.1.1",
        "cmdk": "^1.1.1",
        "concurrently": "^9.2.1",
        "gsap": "^3.15.0",
        "i18next": "^26.2.0",
        "i18next-browser-languagedetector": "^8.2.1",
        "i18next-http-backend": "^3.0.6",
        "jotai": "^2.20.0",
        "lucide-react": "^0.576.0",
        "motion": "^12.38.0",
        "radix-ui": "^1.4.3",
        "react": "^19.2.6",
        "react-dom": "^19.2.6",
        "react-i18next": "^17.0.8",
        "react-resizable-panels": "^4.11.1",
        "shadcn": "^3.8.5",
        "tailwind-merge": "^3.6.0",
        "tailwindcss": "^4.3.0",
        "tw-animate-css": "^1.4.0",
        "vaul": "^1.1.2"
    },
    "devDependencies": {
        "@types/node": "^25.8.0",
        "@types/react": "^19.2.14"
    }
}
