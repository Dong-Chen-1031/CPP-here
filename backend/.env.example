# set to false for production deployment, true for local development
# If DEV is false, it will stop auto reloading and turn off api docs.
# Default: false
DEV="false"

# Port for the backend server to listen on. 
# Default: 8000
PORT="8000"

# Frontend URL for CORS configuration. 
# Default: "http://localhost:4321"
FRONTEND_URL="http://localhost:4321"

# Backend URL for the frontend to fetch data from.
# Default: "http://localhost:8000"
BACKEND_URL="http://localhost:8000"

# Cloudflare Turnstile secret key for CAPTCHA verification.
# Get a real secret key from Cloudflare Turnstile dashboard for production use.
# Default: "1x0000000000000000000000000000000AA" (Always valid for development).
TURNSTILE_SECRET="1x0000000000000000000000000000000AA"

# Set to "true" to skip CAPTCHA checks, which can be useful for local development and testing. 
# In production, this should be set to "false" to ensure security.
BYPASS_CAPTCHA="false"


# A key that can bypass human verification.
# Can be used directly as a JWT key.
CAPTCHA_TEST_TOKEN=""

# how wide your terminal is.
# This is used to format the output of the backend server logs to prevent line breaks in the middle of log lines when running in Docker Compose.
COLUMNS=160
        

# A secure random string used for signing JWT tokens.
# In production, make sure to set this to a strong, unique value and keep it secret.
# Default: not set (auto generated at runtime if not provided, but it's recommended to set it explicitly in production).
# JWT_SECRET=""


# Whether to enable the share feature. If true, users can share their code and results with others via a unique URL. 
# This requires additional storage and may have security implications, so it's disabled by default.
SHARE="false"

# S3-compatible storage configuration for storing shared code and results if the share feature is enabled. 
# This is optional and only needed if SHARE="true". You can use services like AWS S3, DigitalOcean Spaces, or MinIO.
S3_ENDPOINT_URL=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
S3_BUCKET_NAME=""